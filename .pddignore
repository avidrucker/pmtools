# .pddignore — paths pmtools status (PDD marker scan) skips for THIS repo.
# gitignore-style globs, one per line; blank lines and '#' comments ignored.
# Only canonical `@(todo|inprogress) #<issue>:<estimate>` markers are actionable;
# everything below contains marker-like text but no real puzzles.

# --- dependencies / generated ---
node_modules/**

# --- agent harness working dirs ---
.claude/**

# --- golden fixtures + integration scripts carry marker-like TEST DATA
#     (e.g. fixtures/status/*, fixtures/claim/*, tests/integration.sh) ---
fixtures/**
tests/**

# --- colocated unit tests carry canned marker strings as test input. pmtools
#     keeps tests beside sources (js/*.test.js, py/test_*.py) rather than in a
#     tests/ dir, so the tests/** rule above misses them — this is the
#     layout-equivalent of lccjs's `tests/**/*.spec.js` entry (#137). ---
*.test.js
test_*.py

# --- docs + the committed CSV store mirrors (prose / data that quotes markers) ---
docs/**
*.md

# --- the illustrative example ignore file ---
.pddignore.example
