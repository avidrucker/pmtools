[
  { "name": "finds a @todo marker",
    "args": ["359", "scripts/close.js:42:  // @todo #359:30/DEV fix the thing"],
    "expected": { "found": true, "lines": ["scripts/close.js:42:  // @todo #359:30/DEV fix the thing"] } },
  { "name": "finds an @inprogress marker",
    "args": ["359", "src/claim.py:10:  # @inprogress #359:30/DEV fixing"],
    "expected": { "found": true, "lines": ["src/claim.py:10:  # @inprogress #359:30/DEV fixing"] } },
  { "name": "empty grep output → not found",
    "args": ["359", ""], "expected": { "found": false, "lines": [] } },
  { "name": "null grep output → not found",
    "args": ["359", null], "expected": { "found": false, "lines": [] } },
  { "name": "does not match a different issue number",
    "args": ["359", "src/foo.py:5: # @todo #100:20/DEV something else"],
    "expected": { "found": false, "lines": [] } },
  { "name": "case-insensitive on the keyword",
    "args": ["359", "src/x.py:1: @TODO #359:10/DEV"],
    "expected": { "found": true, "lines": ["src/x.py:1: @TODO #359:10/DEV"] } },
  { "name": "issue number mid-word does not match (word boundary)",
    "args": ["359", "src/x.py:1: // @todo #3590:10/DEV other issue"],
    "expected": { "found": false, "lines": [] } },
  { "name": "returns all matched lines when multiple markers present",
    "args": ["359", "src/a.py:1: # @todo #359:10/DEV\nsrc/b.py:2: # @inprogress #359:20/DEV"],
    "expected": { "found": true, "lines": ["src/a.py:1: # @todo #359:10/DEV", "src/b.py:2: # @inprogress #359:20/DEV"] } }
]
