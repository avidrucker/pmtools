[
  { "name": "unchecked box referencing the child → match",
    "args": [[{ "number": 10, "body": "- [ ] do #5 thing" }], 5],
    "expected": [{ "trackerNumber": 10, "line": "- [ ] do #5 thing" }] },
  { "name": "checked box → no match",
    "args": [[{ "number": 10, "body": "- [x] done #5" }], 5],
    "expected": [] },
  { "name": "a different issue → no match",
    "args": [[{ "number": 10, "body": "- [ ] do #6" }], 5],
    "expected": [] },
  { "name": "word boundary: #5 does not match #50",
    "args": [[{ "number": 10, "body": "- [ ] do #50" }], 5],
    "expected": [] },
  { "name": "multiple trackers and matched lines, in order",
    "args": [[{ "number": 10, "body": "- [ ] a #5\n- [ ] b #5" }, { "number": 11, "body": "- [ ] c #5" }], 5],
    "expected": [{ "trackerNumber": 10, "line": "- [ ] a #5" }, { "trackerNumber": 10, "line": "- [ ] b #5" }, { "trackerNumber": 11, "line": "- [ ] c #5" }] },
  { "name": "line is trimmed in the result",
    "args": [[{ "number": 10, "body": "  - [ ] indented #5  " }], 5],
    "expected": [{ "trackerNumber": 10, "line": "- [ ] indented #5" }] },
  { "name": "no issues → empty",
    "args": [[], 5], "expected": [] },
  { "name": "null issues → empty",
    "args": [null, 5], "expected": [] },
  { "name": "string issue number works",
    "args": [[{ "number": 10, "body": "- [ ] #5" }], "5"],
    "expected": [{ "trackerNumber": 10, "line": "- [ ] #5" }] }
]
