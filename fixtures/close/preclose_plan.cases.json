[
  { "name": "absent/null block → no gate (back-compat, #106)",
    "args": [null],
    "expected": { "run": false, "commands": [], "cwd": "worktree" } },
  { "name": "empty commands → no gate",
    "args": [{ "commands": [] }],
    "expected": { "run": false, "commands": [], "cwd": "worktree" } },
  { "name": "commands present, enabled omitted → runs (default on), cwd defaults worktree",
    "args": [{ "commands": ["ruff check ."] }],
    "expected": { "run": true, "commands": ["ruff check ."], "cwd": "worktree" } },
  { "name": "enabled false with commands → disabled",
    "args": [{ "commands": ["ruff check ."], "enabled": false }],
    "expected": { "run": false, "commands": ["ruff check ."], "cwd": "worktree" } },
  { "name": "enabled true, cwd root → runs at repo root",
    "args": [{ "commands": ["pytest -q"], "enabled": true, "cwd": "root" }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "root" } },
  { "name": "filters blank/non-string entries; keeps order + original spacing",
    "args": [{ "commands": ["ruff check .", "", "  ", 5, null, "pytest -q"] }],
    "expected": { "run": true, "commands": ["ruff check .", "pytest -q"], "cwd": "worktree" } },
  { "name": "unknown cwd value falls back to worktree",
    "args": [{ "commands": ["make lint"], "cwd": "elsewhere" }],
    "expected": { "run": true, "commands": ["make lint"], "cwd": "worktree" } },
  { "name": "commands not a list → no gate",
    "args": [{ "commands": "ruff check ." }],
    "expected": { "run": false, "commands": [], "cwd": "worktree" } }
]
