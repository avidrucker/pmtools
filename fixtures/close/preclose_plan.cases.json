[
  { "name": "absent/null block → no gate (back-compat, #106)",
    "args": [null],
    "expected": { "run": false, "commands": [], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "empty commands → no gate",
    "args": [{ "commands": [] }],
    "expected": { "run": false, "commands": [], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "commands present, enabled omitted → runs (default on), cwd defaults worktree",
    "args": [{ "commands": ["ruff check ."] }],
    "expected": { "run": true, "commands": ["ruff check ."], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "enabled false with commands → disabled",
    "args": [{ "commands": ["ruff check ."], "enabled": false }],
    "expected": { "run": false, "commands": ["ruff check ."], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "enabled true, cwd root → runs at repo root",
    "args": [{ "commands": ["pytest -q"], "enabled": true, "cwd": "root" }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "root", "timeoutSec": 0 } },
  { "name": "filters blank/non-string entries; keeps order + original spacing",
    "args": [{ "commands": ["ruff check .", "", "  ", 5, null, "pytest -q"] }],
    "expected": { "run": true, "commands": ["ruff check .", "pytest -q"], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "unknown cwd value falls back to worktree",
    "args": [{ "commands": ["make lint"], "cwd": "elsewhere" }],
    "expected": { "run": true, "commands": ["make lint"], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "commands not a list → no gate",
    "args": [{ "commands": "ruff check ." }],
    "expected": { "run": false, "commands": [], "cwd": "worktree", "timeoutSec": 0 } },

  { "name": "timeoutSec positive int → carried through (#107)",
    "args": [{ "commands": ["pytest -q"], "timeoutSec": 300 }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 300 } },
  { "name": "timeoutSec positive float → carried through (#107)",
    "args": [{ "commands": ["pytest -q"], "timeoutSec": 1.5 }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 1.5 } },
  { "name": "timeoutSec 0 → no limit (0, #107)",
    "args": [{ "commands": ["pytest -q"], "timeoutSec": 0 }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "timeoutSec negative → clamped to 0 (no limit, #107)",
    "args": [{ "commands": ["pytest -q"], "timeoutSec": -5 }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "timeoutSec non-number (string) → 0 (#107)",
    "args": [{ "commands": ["pytest -q"], "timeoutSec": "300" }],
    "expected": { "run": true, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 0 } },
  { "name": "timeoutSec set but gate disabled → still normalized, run false (#107)",
    "args": [{ "commands": ["pytest -q"], "enabled": false, "timeoutSec": 300 }],
    "expected": { "run": false, "commands": ["pytest -q"], "cwd": "worktree", "timeoutSec": 300 } }
]
