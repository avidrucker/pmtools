[
  { "name": "only a configured index conflicted → true",
    "args": [["docs/learnings/README.md"], ["docs/learnings/README.md"]], "expected": true },
  { "name": "index + another file → false (real conflict)",
    "args": [["docs/learnings/README.md", "js/close.js"], ["docs/learnings/README.md"]], "expected": false },
  { "name": "two configured indexes both conflicted → true",
    "args": [["a/idx.md", "b/idx.md"], ["a/idx.md", "b/idx.md"]], "expected": true },
  { "name": "one of several configured indexes conflicted → true",
    "args": [["b/idx.md"], ["a/idx.md", "b/idx.md"]], "expected": true },
  { "name": "empty config list → false (auto-resolve off)",
    "args": [["docs/learnings/README.md"], []], "expected": false },
  { "name": "only a non-index file → false",
    "args": [["js/close.js"], ["docs/learnings/README.md"]], "expected": false },
  { "name": "no conflicted paths → false",
    "args": [[], ["docs/learnings/README.md"]], "expected": false },
  { "name": "null paths → false",
    "args": [null, ["docs/learnings/README.md"]], "expected": false },
  { "name": "null config → false",
    "args": [["docs/learnings/README.md"], null], "expected": false },
  { "name": "whitespace around a path is tolerated → true",
    "args": [[" docs/learnings/README.md "], ["docs/learnings/README.md"]], "expected": true },
  { "name": "blank entries are ignored; lone index → true",
    "args": [["", "docs/learnings/README.md", "  "], ["docs/learnings/README.md"]], "expected": true }
]
