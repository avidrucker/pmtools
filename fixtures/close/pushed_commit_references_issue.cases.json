[
  { "name": "subject references (#N) but no close keyword → true",
    "args": ["chore: tidy up the thing (#25)", "25"], "expected": true },
  { "name": "bare #N reference in body, no keyword → true",
    "args": ["feat: add knob\n\nsee #25 for context", "25"], "expected": true },
  { "name": "reference with trailing punctuation → true",
    "args": ["mention #25.", "25"], "expected": true },
  { "name": "Closes #N keyword present → false (it closes, not the target case)",
    "args": ["fix: bar\n\nCloses #25\n", "25"], "expected": false },
  { "name": "Fixes #N keyword → false",
    "args": ["Fixes #25", "25"], "expected": false },
  { "name": "Resolves #N keyword → false",
    "args": ["Resolves #25", "25"], "expected": false },
  { "name": "references AND closes in concatenated text → false (it closes)",
    "args": ["chore: foo (#25)\n\nCloses #25", "25"], "expected": false },
  { "name": "wrong issue number (#26) → false",
    "args": ["chore: x (#26)", "25"], "expected": false },
  { "name": "longer number #250 does not match #25 (word boundary) → false",
    "args": ["chore: x (#250)", "25"], "expected": false },
  { "name": "no #N reference at all → false",
    "args": ["chore: unrelated work", "25"], "expected": false },
  { "name": "empty → false", "args": ["", "25"], "expected": false },
  { "name": "null → false", "args": [null, "25"], "expected": false }
]
