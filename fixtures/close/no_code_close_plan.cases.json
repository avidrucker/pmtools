[
  { "name": "inline comment → ok, source inline",
    "args": [{ "comment": "findings here", "commentFile": null, "noComment": false }],
    "expected": { "ok": true, "source": "inline" } },
  { "name": "comment-file → ok, source file",
    "args": [{ "comment": null, "commentFile": "notes.md", "noComment": false }],
    "expected": { "ok": true, "source": "file" } },
  { "name": "--no-comment → ok, source none",
    "args": [{ "comment": null, "commentFile": null, "noComment": true }],
    "expected": { "ok": true, "source": "none" } },
  { "name": "empty-string inline comment is still a comment (not missing)",
    "args": [{ "comment": "", "commentFile": null, "noComment": false }],
    "expected": { "ok": true, "source": "inline" } },
  { "name": "both comment sources → usage error",
    "args": [{ "comment": "x", "commentFile": "notes.md", "noComment": false }],
    "expected": { "ok": false, "error": "provide only one of --comment or --comment-file" } },
  { "name": "--no-comment plus an inline comment → usage error",
    "args": [{ "comment": "x", "commentFile": null, "noComment": true }],
    "expected": { "ok": false, "error": "--no-comment cannot be combined with --comment or --comment-file" } },
  { "name": "--no-comment plus a comment-file → usage error",
    "args": [{ "comment": null, "commentFile": "notes.md", "noComment": true }],
    "expected": { "ok": false, "error": "--no-comment cannot be combined with --comment or --comment-file" } },
  { "name": "no comment source and no --no-comment → usage error (comment required)",
    "args": [{ "comment": null, "commentFile": null, "noComment": false }],
    "expected": { "ok": false, "error": "--no-code requires a closing comment: pass --comment, --comment-file, or --no-comment to close without one" } }
]
