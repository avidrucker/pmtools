[
  { "name": "a single issue number, no flags",
    "args": [["44"]],
    "expected": { "issue": "44", "force": false } },
  { "name": "issue number then --force",
    "args": [["44", "--force"]],
    "expected": { "issue": "44", "force": true } },
  { "name": "--force before the issue number (order-independent)",
    "args": [["--force", "44"]],
    "expected": { "issue": "44", "force": true } },
  { "name": "a bare -- separator is skipped",
    "args": [["--", "44"]],
    "expected": { "issue": "44", "force": false } },
  { "name": "no issue → issue null (the wrapper turns this into a usage die)",
    "args": [[]],
    "expected": { "issue": null, "force": false } },
  { "name": "--force but no issue → issue null, force recorded",
    "args": [["--force"]],
    "expected": { "issue": null, "force": true } },
  { "name": "two issue numbers → raises (unexpected extra arg)",
    "args": [["44", "45"]],
    "expected_error": true },
  { "name": "a non-numeric positional → raises (unknown arg)",
    "args": [["foo"]],
    "expected_error": true },
  { "name": "an unknown --flag → raises (unknown arg)",
    "args": [["44", "--bogus"]],
    "expected_error": true }
]
