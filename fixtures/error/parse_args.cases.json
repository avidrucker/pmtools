[
  { "name": "log subcommand with a json positional",
    "args": [["log", "{\"message\":\"x\"}"]],
    "expected": { "cmd": "log", "json": "{\"message\":\"x\"}", "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "export subcommand, no json positional",
    "args": [["export"]],
    "expected": { "cmd": "export", "json": null, "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "empty argv → all null/false (cmd null)",
    "args": [[]],
    "expected": { "cmd": null, "json": null, "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "--db-path consumes the next token as its value",
    "args": [["log", "{}", "--db-path", "/tmp/x.db"]],
    "expected": { "cmd": "log", "json": "{}", "dbPath": "/tmp/x.db", "csv": null, "noCsv": false } },
  { "name": "--db-path as the LAST token → null (no value to consume)",
    "args": [["log", "--db-path"]],
    "expected": { "cmd": "log", "json": null, "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "--csv consumes the next token as its value",
    "args": [["export", "--csv", "/tmp/x.csv"]],
    "expected": { "cmd": "export", "json": null, "dbPath": null, "csv": "/tmp/x.csv", "noCsv": false } },
  { "name": "--csv as the LAST token → null (no value to consume)",
    "args": [["export", "--csv"]],
    "expected": { "cmd": "export", "json": null, "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "--no-csv sets the noCsv flag",
    "args": [["log", "{}", "--no-csv"]],
    "expected": { "cmd": "log", "json": "{}", "dbPath": null, "csv": null, "noCsv": true } },
  { "name": "--csv and --no-csv together are both recorded (precedence is resolveCsv's job)",
    "args": [["log", "{}", "--csv", "/tmp/x.csv", "--no-csv"]],
    "expected": { "cmd": "log", "json": "{}", "dbPath": null, "csv": "/tmp/x.csv", "noCsv": true } },
  { "name": "only the first two positionals become cmd/json; extras are ignored",
    "args": [["log", "{}", "extra"]],
    "expected": { "cmd": "log", "json": "{}", "dbPath": null, "csv": null, "noCsv": false } },
  { "name": "an unknown --flag raises (wrapper turns this into a usage die, exit 2)",
    "args": [["log", "--bogus"]],
    "expected_error": true }
]
