[
  { "name": "--as is the explicit override and wins over the env var",
    "args": [{ "as": "cherry" }, { "CLAUDE_AGENT_NAME": "dragonfruit" }],
    "expected": { "name": "cherry", "source": "as", "modeLabel": "reuse (--as)" } },
  { "name": "CLAUDE_AGENT_NAME is the human-directed default when --as is absent",
    "args": [{ "as": null }, { "CLAUDE_AGENT_NAME": "DRAGONFRUIT" }],
    "expected": { "name": "dragonfruit", "source": "env", "modeLabel": "human-directed (env)" } },
  { "name": "no --as and no env var falls back to auto (name null)",
    "args": [{ "as": null }, {}],
    "expected": { "name": null, "source": "auto", "modeLabel": "auto" } },
  { "name": "a whitespace-only env var is treated as unset (auto fallback)",
    "args": [{ "as": null }, { "CLAUDE_AGENT_NAME": "   " }],
    "expected": { "name": null, "source": "auto", "modeLabel": "auto" } },
  { "name": "a non-fruit human name is honored verbatim (only normalized)",
    "args": [{ "as": null }, { "CLAUDE_AGENT_NAME": "Pineapple" }],
    "expected": { "name": "pineapple", "source": "env", "modeLabel": "human-directed (env)" } },
  { "name": "branch-inferred fires when --as and env are both absent",
    "args": [{ "as": null }, {}, "cherry/issue-180-slug"],
    "expected": { "name": "cherry", "source": "branch", "modeLabel": "branch-inferred" } },
  { "name": "--as wins over branch-inferred",
    "args": [{ "as": "apple" }, {}, "cherry/issue-180-slug"],
    "expected": { "name": "apple", "source": "as", "modeLabel": "reuse (--as)" } },
  { "name": "CLAUDE_AGENT_NAME wins over branch-inferred",
    "args": [{ "as": null }, { "CLAUDE_AGENT_NAME": "dragonfruit" }, "cherry/issue-180-slug"],
    "expected": { "name": "dragonfruit", "source": "env", "modeLabel": "human-directed (env)" } },
  { "name": "non-fruit-issue branch falls through to auto",
    "args": [{ "as": null }, {}, "main"],
    "expected": { "name": null, "source": "auto", "modeLabel": "auto" } },
  { "name": "null branch falls through to auto",
    "args": [{ "as": null }, {}, null],
    "expected": { "name": null, "source": "auto", "modeLabel": "auto" } }
]
