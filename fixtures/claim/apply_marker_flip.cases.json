[
  { "name": "flips @todo to @inprogress, preserving the :Est/ROLE remainder",
    "args": ["// @todo #42:30m/DEV fix the thing\n", "42"],
    "expected": { "updated": "// @inprogress #42:30m/DEV fix the thing\n", "flipped": true, "line": 1 } },
  { "name": "does not match a larger issue number (@todo #420 must not match issue 42)",
    "args": ["// @todo #420:30m/DEV\n", "42"],
    "expected": { "updated": "// @todo #420:30m/DEV\n", "flipped": false, "line": 0 } },
  { "name": "matches a canonical marker at end of line with no trailing character",
    "args": ["// @todo #99:30m/DEV\n", "99"],
    "expected": { "updated": "// @inprogress #99:30m/DEV\n", "flipped": true, "line": 1 } },
  { "name": "matches a canonical marker at the very end of content (no newline)",
    "args": ["// @todo #99:30m/DEV", "99"],
    "expected": { "updated": "// @inprogress #99:30m/DEV", "flipped": true, "line": 1 } },
  { "name": "does NOT flip a bare @todo #N with no :Est/ROLE tail (#1116)",
    "args": ["// see @todo #88 in ilcc.js\n", "88"],
    "expected": { "updated": "// see @todo #88 in ilcc.js\n", "flipped": false, "line": 0 } },
  { "name": "does NOT flip a velocity-CSV-style note mentioning the marker (#1116)",
    "args": ["975,1027,research note,...,@todo #1028 placed,ELDERBERRY,opus-4.8,lccjs\n", "1028"],
    "expected": { "updated": "975,1027,research note,...,@todo #1028 placed,ELDERBERRY,opus-4.8,lccjs\n", "flipped": false, "line": 0 } },
  { "name": "flips the canonical marker even when a bare mention precedes it (#1116)",
    "args": ["# note: @todo #1028 placed\n// @todo #1028:45m/RESEARCH wire it up\n", "1028"],
    "expected": { "updated": "# note: @todo #1028 placed\n// @inprogress #1028:45m/RESEARCH wire it up\n", "flipped": true, "line": 2 } },
  { "name": "returns content unchanged and flipped=false when no marker present",
    "args": ["no markers here\n", "42"],
    "expected": { "updated": "no markers here\n", "flipped": false, "line": 0 } },
  { "name": "reports the correct 1-indexed line number for multi-line content",
    "args": ["line one\nline two\n// @todo #7:15m/DEV something\nline four\n", "7"],
    "expected": { "updated": "line one\nline two\n// @inprogress #7:15m/DEV something\nline four\n", "flipped": true, "line": 3 } },
  { "name": "does not match @inprogress — already-flipped content returns flipped=false",
    "args": ["// @inprogress #42:30m/DEV fix the thing\n", "42"],
    "expected": { "updated": "// @inprogress #42:30m/DEV fix the thing\n", "flipped": false, "line": 0 } },
  { "name": "only flips the first occurrence when multiple @todo #N lines exist",
    "args": ["// @todo #5:10m/DEV first\n// @todo #5:10m/DEV second\n", "5"],
    "expected": { "updated": "// @inprogress #5:10m/DEV first\n// @todo #5:10m/DEV second\n", "flipped": true, "line": 1 } }
]
