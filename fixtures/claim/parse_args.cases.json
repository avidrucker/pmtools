[
  { "name": "parses the issue number and an explicit --as override",
    "args": [["212", "some-slug", "--as", "banana"]],
    "expected": { "issue": "212", "slug": "some-slug", "as": "banana", "base": "main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": false } },
  { "name": "leaves as null when --as is omitted",
    "args": [["212"]],
    "expected": { "issue": "212", "slug": null, "as": null, "base": "main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": false } },
  { "name": "--allow-stale-main sets the bypass flag",
    "args": [["228", "--allow-stale-main"]],
    "expected": { "issue": "228", "slug": null, "as": null, "base": "main", "dryRun": false, "allowStaleMain": true, "force": false, "custom": false, "allowUncategorized": false } },
  { "name": "--custom sets custom=true",
    "args": [["212", "--as", "dragonfruit", "--custom"]],
    "expected": { "issue": "212", "slug": null, "as": "dragonfruit", "base": "main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": true, "allowUncategorized": false } },
  { "name": "--allow-uncategorized sets allowUncategorized true",
    "args": [["239", "--allow-uncategorized"]],
    "expected": { "issue": "239", "slug": null, "as": null, "base": "main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": true } },
  { "name": "--no-lane-check is an accepted alias for --allow-uncategorized",
    "args": [["239", "--no-lane-check"]],
    "expected": { "issue": "239", "slug": null, "as": null, "base": "main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": true } },
  { "name": "--force sets force true",
    "args": [["239", "--force"]],
    "expected": { "issue": "239", "slug": null, "as": null, "base": "main", "dryRun": false, "allowStaleMain": false, "force": true, "custom": false, "allowUncategorized": false } },
  { "name": "--dry-run sets dryRun true",
    "args": [["123", "--dry-run"]],
    "expected": { "issue": "123", "slug": null, "as": null, "base": "main", "dryRun": true, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": false } },
  { "name": "--base overrides the default base",
    "args": [["123", "--base", "origin/main"]],
    "expected": { "issue": "123", "slug": null, "as": null, "base": "origin/main", "dryRun": false, "allowStaleMain": false, "force": false, "custom": false, "allowUncategorized": false } },
  { "name": "all flags together with issue and slug positionals",
    "args": [["500", "my-slug", "--as", "kiwi", "--base", "origin/main", "--dry-run", "--force", "--allow-stale-main", "--allow-uncategorized", "--custom"]],
    "expected": { "issue": "500", "slug": "my-slug", "as": "kiwi", "base": "origin/main", "dryRun": true, "allowStaleMain": true, "force": true, "custom": true, "allowUncategorized": true } }
]
