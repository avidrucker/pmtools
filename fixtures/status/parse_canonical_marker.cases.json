[
  { "name": "canonical todo with minute estimate + role",
    "args": ["@todo #134:60m/ARC implement X"],
    "expected": { "keyword": "@todo", "issue": 134, "estimate": "60m" } },
  { "name": "canonical inprogress with bare-digit estimate",
    "args": ["// @inprogress #252:30 wip"],
    "expected": { "keyword": "@inprogress", "issue": 252, "estimate": "30" } },
  { "name": "estimate-less marker → null (prose, not a puzzle)",
    "args": ["@todo #208 see comments for the rationale"], "expected": null },
  { "name": "marker with no issue number → null",
    "args": ["@todo finish this later"], "expected": null },
  { "name": "prose mention of the keyword without # → null",
    "args": ["the @todo scanner trips on this line"], "expected": null },
  { "name": "uppercase keyword is normalised to lowercase",
    "args": ["@TODO #7:5m quick fix"],
    "expected": { "keyword": "@todo", "issue": 7, "estimate": "5m" } },
  { "name": "spec-fixture number IS canonical if it carries an estimate (location handled by .pddignore)",
    "args": ["expect(scan('@todo #9102:15m')).toBe(1)"],
    "expected": { "keyword": "@todo", "issue": 9102, "estimate": "15m" } },
  { "name": "missing colon estimate → null",
    "args": ["@todo #143 docs note"], "expected": null },
  { "name": "no marker at all → null", "args": ["just an ordinary comment"], "expected": null },
  { "name": "empty → null", "args": [""], "expected": null },
  { "name": "null → null", "args": [null], "expected": null }
]
