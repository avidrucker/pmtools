[
  { "name": "no args → defaults (branchPattern null; each wrapper fills its own default)",
    "args": [[]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--strict sets strict",
    "args": [["--strict"]],
    "expected": { "strict": true, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--json sets json",
    "args": [["--json"]],
    "expected": { "strict": false, "json": true, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--strict and --json together",
    "args": [["--strict", "--json"]],
    "expected": { "strict": true, "json": true, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--host overrides the default host",
    "args": [["--host", "gitlab"]],
    "expected": { "strict": false, "json": false, "host": "gitlab", "branchPattern": null, "limit": 50 } },
  { "name": "--host as the LAST token → null (no value to consume)",
    "args": [["--host"]],
    "expected": { "strict": false, "json": false, "host": null, "branchPattern": null, "limit": 50 } },
  { "name": "--branch-pattern overrides (explicit value is identical across ports)",
    "args": [["--branch-pattern", "^x/issue-(?<issue>\\d+)"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": "^x/issue-(?<issue>\\d+)", "limit": 50 } },
  { "name": "--branch-pattern as the LAST token → null (wrapper fills its default)",
    "args": [["--branch-pattern"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--limit parses an integer",
    "args": [["--limit", "10"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 10 } },
  { "name": "--limit as the LAST token → falls back to 50",
    "args": [["--limit"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "--limit with a non-numeric value → falls back to 50",
    "args": [["--limit", "abc"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "a bare non-flag positional is ignored (status takes no positionals)",
    "args": [["foo"]],
    "expected": { "strict": false, "json": false, "host": "github", "branchPattern": null, "limit": 50 } },
  { "name": "an unknown --flag raises (wrapper turns this into a usage die, exit 2)",
    "args": [["--bogus"]],
    "expected_error": true }
]
