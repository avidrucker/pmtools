  { "name": "drops a confirmed-CLOSED claim (the live #44 stale ref)",
    "args": [[44, 50], [{ "number": 44, "state": "CLOSED" }, { "number": 50, "state": "OPEN" }]],
    "expected": [50] },
  { "name": "keeps OPEN claims",
    "args": [[12, 13], [{ "number": 12, "state": "OPEN" }, { "number": 13, "state": "OPEN" }]],
