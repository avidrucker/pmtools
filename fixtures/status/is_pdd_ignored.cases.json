[
  { "name": "spec fixture excluded by tests/**/*.spec.js",
    "args": ["tests/new/claim.e2e.spec.js", ["tests/**/*.spec.js", "docs/**", "*.md"]],
    "expected": true },
  { "name": "spec fixture directly under tests/ (zero subdirs) still excluded",
    "args": ["tests/claim.spec.js", ["tests/**/*.spec.js"]], "expected": true },
  { "name": "non-spec file under tests/ survives",
    "args": ["tests/helpers/util.js", ["tests/**/*.spec.js"]], "expected": false },
  { "name": "root markdown excluded by *.md",
    "args": ["CLAUDE.md", ["tests/**/*.spec.js", "*.md"]], "expected": true },
  { "name": "nested markdown excluded by *.md (no-slash pattern matches at any depth)",
    "args": ["docs/pitfalls.md", ["*.md"]], "expected": true },
  { "name": "csv under docs excluded by docs/**",
    "args": ["docs/puzzle-velocity.csv", ["docs/**"]], "expected": true },
  { "name": "single-star does NOT cross a slash",
    "args": ["stats/sub/b.csv", ["stats/*.csv"]], "expected": false },
  { "name": "single-star matches a direct child",
    "args": ["stats/a.csv", ["stats/*.csv"]], "expected": true },
  { "name": "dotted dir glob",
    "args": [".claude/worktrees/x", [".claude/**"]], "expected": true },
  { "name": "no-slash pattern matches basename at any depth",
    "args": ["sub/.pddignore", [".pddignore"]], "expected": true },
  { "name": "real code marker site is NOT ignored by the full lccjs set",
    "args": ["src/core/interpreter.js",
      ["node_modules/**", ".claude/**", "tests/**/*.spec.js", "docs/**", "*.md", "stats/*.csv", ".pddignore"]],
    "expected": false },
  { "name": "no patterns → nothing ignored",
    "args": ["anything.js", []], "expected": false },
  { "name": "flood: a spec fixture under tests/ is excluded by tests/**",
    "args": ["tests/new/claim.e2e.spec.js", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": true },
  { "name": "flood: a non-md doc is excluded by docs/** (isolates docs/** from *.md)",
    "args": ["docs/notes.txt", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": true },
  { "name": "flood: a root markdown file is excluded by *.md",
    "args": ["README.md", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": true },
  { "name": "flood: a stats csv is excluded by stats/*.csv",
    "args": ["stats/run-42.csv", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": true },
  { "name": "flood: a worktree path is excluded by .claude/**",
    "args": [".claude/worktrees/wt-x/marker.js", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": true },
  { "name": "flood: a real source marker site survives the full flood policy (the one actionable site)",
    "args": ["js/status_core.js", ["tests/**", "docs/**", "*.md", "stats/*.csv", ".claude/**"]],
    "expected": false }
]
